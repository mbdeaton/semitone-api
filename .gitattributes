# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Explicitly declare text files
*.py        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.sh        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.sql       text eol=lf
*.env       text eol=lf
*.in        text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
LICENSE     text eol=lf

# Denote binary files that should not be modified
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
